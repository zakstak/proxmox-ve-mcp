{
  "name": "proxmox-ve-mcp",
  "version": "1.0.0",
  "description": "Skills-first Proxmox VE onboarding for OpenCode with a read-only default and legacy MCP runtime compatibility",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:readonly": "tsx watch src/index-readonly.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:readonly": "node dist/index-readonly.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "proxmox",
    "opencode",
    "skills",
    "legacy-mcp",
    "mcp",
    "model-context-protocol",
    "virtualization",
    "homelab"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "proxmox-api": "^1.1.1",
    "undici": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
		"@eslint/js": "^9.39.5",
    "@types/node": "^20.19.43",
		"@typescript-eslint/eslint-plugin": "^8.64.0",
		"@typescript-eslint/parser": "^8.64.0",
		"eslint": "^9.39.5",
		"tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
