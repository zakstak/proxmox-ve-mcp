{
  "name": "proxmox-ve-mcp",
  "version": "1.0.0",
  "description": "MCP server for Proxmox VE management with SAGA security architecture",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:readonly": "tsx watch src/index-readonly.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:readonly": "node dist/index-readonly.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "proxmox",
    "mcp",
    "model-context-protocol",
    "virtualization",
    "homelab"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv": "^17.2.4",
    "proxmox-api": "^1.0.0",
    "undici": "^7.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
