{
  "name": "proxmox-ve-mcp",
  "version": "1.0.0",
  "description": "MCP server for Proxmox VE management with SAGA security architecture",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:readonly": "tsx watch src/index-readonly.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:readonly": "node dist/index-readonly.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "proxmox",
    "mcp",
    "model-context-protocol",
    "virtualization",
    "homelab"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "proxmox-api": "^1.0.0",
    "undici": "^6.23.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
