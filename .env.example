# Proxmox VE MCP Server Configuration
# Copy this file to .env and fill in your values

# Proxmox Connection
PROXMOX_HOST=192.168.4.111
PROXMOX_PORT=8006
PROXMOX_NODE=pve

# Authentication (API Token - created via: pveum user token add root@pam mcp-server --privsep 0)
PROXMOX_TOKEN_ID=root@pam!mcp-server
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSL Verification (set to false for self-signed certs)
PROXMOX_VERIFY_SSL=false

# Logging
LOG_LEVEL=info
