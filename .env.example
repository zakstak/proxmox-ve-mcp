# Proxmox VE MCP Server Configuration
# Copy this file to .env and fill in your values

# Proxmox Connection
PROXMOX_HOST=192.168.4.111
PROXMOX_PORT=8006
PROXMOX_NODE=pve

# Authentication
# Recommended default: use a dedicated non-root user and a privilege-separated token with the minimum ACLs needed.
# Proxmox documents PVEAuditor as a read-only starting point; exact ACLs depend on the API methods you plan to use.
PROXMOX_TOKEN_ID=readonly@pam!opencode
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Elevated admin option (explicitly opt-in): use a full-privilege token such as root@pam only when you switch to the full MCP runtime/config.
# PROXMOX_TOKEN_ID=root@pam!mcp-server
# PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# SSL Verification (set to false for self-signed certs)
PROXMOX_VERIFY_SSL=false

# Logging
LOG_LEVEL=info
